# Copy this file to .env and fill in the values.

# Which model to use: "groq" (free, default) or "openai".
MODEL_PROVIDER=groq

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (only needed if MODEL_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Google Sheet access
GOOGLE_CREDENTIALS_PATH=
SHEET_URL=
SHEET_TAB=New Vision
