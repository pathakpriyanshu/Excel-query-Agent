# Copy this file to .env and fill in the values.

# Which model to use: "groq" (free, default) or "openai".
MODEL_PROVIDER=groq

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (only needed if MODEL_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Speech-to-text (mic button). Independent of MODEL_PROVIDER above, so the
# chat LLM and the transcriber can use different providers.
#   STT_PROVIDER=groq    -> uses GROQ_API_KEY  + GROQ_STT_MODEL   (free tier)
#   STT_PROVIDER=openai  -> uses OPENAI_API_KEY + OPENAI_STT_MODEL
STT_PROVIDER=openai
GROQ_STT_MODEL=whisper-large-v3-turbo
OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# Google Sheet access
GOOGLE_CREDENTIALS_PATH=
SHEET_URL=
SHEET_TAB=New Vision
